{
  "name": "claude-better-usage",
  "publisher": "ijuani",
  "displayName": "Claude Code - Better Usage",
  "description": "Shows Claude Code usage (rate limits) in the VSCode status bar",
  "icon": "favicon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IJuanI/claude-usage-bar"
  },
  "version": "0.2.2",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeUsageBar.refresh",
        "title": "Claude Usage Bar: Refresh"
      },
      {
        "command": "claudeUsageBar.openPanel",
        "title": "Claude Usage Bar: Open Panel"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "claudeUsageBar.usageView",
          "name": "Claude Usage"
        }
      ]
    },
    "configuration": {
      "title": "Claude Usage Bar",
      "properties": {
        "claudeUsageBar.refreshInterval": {
          "type": "number",
          "default": 60,
          "description": "How often to refresh usage data (seconds)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "tsc -watch -p ./",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
